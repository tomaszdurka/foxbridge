# Server Configuration
PORT=3100

# Workspace Configuration
# Custom directory for Claude workspaces (optional)
# Default: ./workspaces (relative to project root)
# WORKSPACES_DIR=/var/data/run-workspaces

# Database Configuration
# SQLite database path (optional)
# Default: ./data/foxbridge.db (relative to project root)
# DATABASE_PATH=./data/foxbridge.db
